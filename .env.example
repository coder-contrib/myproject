# ===========================================
# Ceramix AI ERP - Environment Variables
# ===========================================
# Copy this file to .env and fill in values
# ===========================================

# --- Application ---
API_PORT=8000
SHOW_DOCS=true

# --- Database ---
POSTGRES_USER=ceramix
POSTGRES_PASSWORD=ceramix_secret
POSTGRES_DB=ceramix_erp
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ceramix:ceramix_secret@postgres:5432/ceramix_erp

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- AI / OpenAI-Compatible API ---
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key-here
AI_CHAT_MODEL=gpt-4o
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.1

# --- File Storage ---
FILE_STORAGE_PROVIDER=local
FILE_LOCAL_PATH=./uploads
FILE_MAX_SIZE=52428800
# S3-Compatible Storage (uncomment to use)
# FILE_STORAGE_PROVIDER=s3
# FILE_S3_ENDPOINT=https://s3.amazonaws.com
# FILE_S3_ACCESS_KEY=your-access-key
# FILE_S3_SECRET_KEY=your-secret-key
# FILE_S3_BUCKET=erp-files
# FILE_S3_REGION=us-east-1

# --- Security ---
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Logging & Monitoring ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout
METRICS_ENABLED=true
METRICS_PREFIX=ceramix_erp
ERROR_TRACKING_ENABLED=true
PERF_SLOW_THRESHOLD_MS=1000
AUDIT_LOG_ENABLED=true

# --- Webhooks ---
WEBHOOK_MAX_RETRIES=5
WEBHOOK_TIMEOUT=30

# --- Reports ---
REPORT_EXPORT_PATH=./exports
REPORT_COMPANY_NAME=Ceramix AI ERP
REPORT_CURRENCY=$

# --- Prometheus & Grafana ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
